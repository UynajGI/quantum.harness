<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>__PAGE_TITLE__</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=Inter:wght@400;450;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --parchment: #f5f4ed; --ivory: #faf9f5; --sand: #e8e6dc;
    --border-cream: #f0eee6; --border-warm: #e8e6dc; --ring-warm: #d1cfc5;
    --near-black: #141413; --charcoal: #4d4c48; --olive: #5e5d59;
    --stone: #87867f; --silver: #b0aea5;
    --terracotta: #c96442; --coral: #d97757;
    --paper-band: rgba(94, 93, 89, 0.10);
    --serif: 'Source Serif 4', 'Tiempos Headline', Georgia, serif;
    --sans: 'Inter', system-ui, -apple-system, Arial, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', Menlo, ui-monospace, monospace;
  }
  *, *::before, *::after { box-sizing: border-box; }
  html, body { background: var(--parchment); margin: 0; padding: 0; overflow-x: hidden; }
  body { font-family: var(--sans); color: var(--near-black); -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
  ::selection { background: var(--terracotta); color: var(--ivory); }

  .topbar { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 24px;
    max-width: 1240px; margin: 0 auto; padding: 22px 40px; border-bottom: 1px solid var(--border-warm); }
  .topbar .id { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.06em; color: var(--terracotta); border: 1px solid var(--terracotta); padding: 4px 10px; border-radius: 4px; display: inline-block; margin-right: 14px; }
  .topbar .paper { font-family: var(--sans); font-size: 13px; color: var(--olive); }
  .topbar .paper b { color: var(--near-black); font-weight: 500; }
  .topbar .paper a { color: var(--terracotta); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 150ms ease; }
  .topbar .paper a:hover { border-bottom-color: var(--terracotta); }
  .topbar .meta { font-family: var(--mono); font-size: 11px; color: var(--stone); text-align: right; line-height: 1.6; }

  .hero { max-width: 1240px; margin: 0 auto; padding: 36px 40px 28px; }
  .claim-line { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 26px; }
  .claim { font-family: var(--serif); font-weight: 500; font-size: 32px; line-height: 1.18;
    color: var(--near-black); letter-spacing: -0.012em; text-wrap: balance; margin: 0; }
  .claim em { font-style: italic; color: var(--terracotta); font-weight: 500; }
  .claim .sym { font-family: var(--serif); font-style: italic; border-bottom: 1px dotted var(--stone); cursor: help; transition: border-color 150ms ease; }
  .claim .sym:hover { border-bottom-color: var(--terracotta); border-bottom-style: solid; }
  .claim-tag { font-family: var(--sans); font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terracotta); white-space: nowrap; flex-shrink: 0; padding-top: 6px; }

  /* ===== SIDE-BY-SIDE ===== */
  .duo {
    display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
  }
  .panel-card {
    background: var(--ivory);
    border: 1px solid var(--border-cream);
    border-radius: 24px;
    padding: 24px 26px 18px;
    box-shadow: 0 0 0 1px var(--border-cream), 0 6px 32px rgba(20,20,19,0.05);
    position: relative;
    display: flex; flex-direction: column;
  }
  .panel-head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 14px;
    font-family: var(--sans);
  }
  .panel-head .label {
    font-size: 10px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--terracotta);
  }
  .panel-head .label.ref { color: var(--olive); }
  .panel-head .source { font-family: var(--mono); font-size: 10.5px; color: var(--stone); }
  .panel-title {
    font-family: var(--serif); font-weight: 500; font-size: 16px; line-height: 1.30;
    color: var(--near-black); margin: 0 0 14px;
    letter-spacing: -0.005em;
  }

  .paper-img-wrap {
    background: #fff; border: 1px solid var(--border-cream); border-radius: 12px;
    padding: 18px 22px; flex: 1;
    display: flex; align-items: center; justify-content: center;
    min-height: 360px;
  }
  .paper-img-wrap img {
    max-width: 100%; height: auto; display: block;
    image-rendering: -webkit-optimize-contrast;
  }
  .paper-cap {
    margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--border-cream);
    font-family: var(--sans); font-size: 12.5px; line-height: 1.6; color: var(--olive);
  }
  .paper-cap b { color: var(--near-black); font-weight: 500; }

  /* Reproduction plot */
  .plot-area { position: relative; min-height: 360px; flex: 1; }
  svg.plot { width: 100%; height: 360px; user-select: none; display: block; }
  svg.plot .grid { stroke: var(--border-warm); stroke-dasharray: 1 4; stroke-width: 0.5; }
  svg.plot .axis { stroke: var(--stone); stroke-width: 0.8; }
  svg.plot .axis-label { fill: var(--olive); font-size: 12px; font-family: var(--sans); font-weight: 450; }
  svg.plot .tick { fill: var(--stone); font-size: 10.5px; font-family: var(--mono); }
  svg.plot .curve { fill: none; stroke-width: 1.7; transition: opacity 220ms ease, stroke-width 220ms ease; }
  svg.plot .curve.dim { opacity: 0.18; }
  svg.plot .curve.focus { stroke-width: 2.6; }
  svg.plot .pt { transition: opacity 200ms ease, r 140ms ease; cursor: pointer; }
  svg.plot .pt.dim { opacity: 0.18; }
  svg.plot .errbar { stroke-width: 1.2; opacity: 0.50; transition: opacity 220ms ease; }
  svg.plot .errbar.dim { opacity: 0.10; }
  svg.plot .draw { stroke-dasharray: 2400; stroke-dashoffset: 2400; animation: draw 1100ms cubic-bezier(0.32, 0.72, 0, 1) forwards; }
  svg.plot .zero { stroke: var(--silver); stroke-width: 0.6; opacity: 0.5; }
  svg.plot .hcline { stroke: var(--terracotta); stroke-width: 0.6; stroke-dasharray: 4 4; opacity: 0.55; }
  svg.plot .hclabel { fill: var(--terracotta); font-family: var(--mono); font-size: 11px; opacity: 0.85; }
  svg.plot .paper-window { fill: var(--paper-band); stroke: none; opacity: 0; transition: opacity 320ms ease; pointer-events: none; }
  svg.plot .paper-window.on { opacity: 1; }
  svg.plot .paper-window-label { fill: var(--olive); font-family: var(--sans); font-size: 10.5px; font-style: italic; opacity: 0; transition: opacity 320ms ease; }
  svg.plot .paper-window-label.on { opacity: 0.85; }
  @keyframes draw { to { stroke-dashoffset: 0; } }

  .ours-controls {
    position: absolute; top: 22px; right: 26px; display: flex; gap: 6px;
  }
  .toggle {
    font-family: var(--sans); font-size: 11px; font-weight: 500;
    background: var(--parchment); border: 1px solid var(--border-warm);
    color: var(--charcoal); border-radius: 999px; padding: 4px 10px;
    cursor: pointer; transition: all 160ms ease;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .toggle:hover { background: var(--sand); }
  .toggle.on { background: var(--near-black); color: var(--ivory); border-color: var(--near-black); }
  .toggle .swatch { width: 9px; height: 9px; border-radius: 2px; background: var(--paper-band); border: 1px solid var(--silver); }
  .toggle.on .swatch { background: var(--ivory); border-color: var(--ivory); opacity: 0.6; }

  .legend-row {
    display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
    margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border-cream);
  }
  .legend-item {
    display: flex; align-items: center; gap: 8px;
    padding: 4px 10px; border-radius: 16px; cursor: pointer;
    font-family: var(--sans); font-size: 12.5px; color: var(--charcoal);
    transition: background 150ms ease, opacity 150ms ease;
  }
  .legend-item:hover { background: var(--sand); }
  .legend-item.dim { opacity: 0.40; }
  .legend-swatch { width: 16px; height: 3px; border-radius: 2px; }
  .legend-val { font-family: var(--mono); font-size: 11.5px; color: var(--stone); }

  /* ===== STATUS STRIP ===== */
  .strip {
    max-width: 1240px; margin: 22px auto 0; padding: 0 40px;
    display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
  }
  .chip {
    font-family: var(--sans); font-size: 12px;
    background: var(--ivory); border: 1px solid var(--border-warm);
    color: var(--charcoal); border-radius: 999px;
    padding: 5px 12px;
    display: inline-flex; align-items: center; gap: 7px;
    cursor: help; position: relative;
    transition: background 150ms ease;
    font-variant-numeric: tabular-nums;
  }
  .chip:hover { background: var(--sand); }
  .chip.ok::before { content: '✓'; color: var(--olive); font-weight: 500; }
  .chip.warn { border-color: var(--terracotta); color: var(--terracotta); }
  .chip.warn::before { content: '⚠'; }
  .chip.warn:hover { background: rgba(201,100,66,0.06); }
  .chip.muted { color: var(--stone); border-color: var(--border-cream); }
  .chip.spacer { flex: 1; background: none; border: none; padding: 0; cursor: default; }

  .chip-pop {
    position: absolute; bottom: calc(100% + 8px); left: 0;
    background: var(--near-black); color: var(--silver);
    border-radius: 8px; padding: 8px 12px;
    font-size: 12px; line-height: 1.5; max-width: 280px;
    box-shadow: 0 8px 24px rgba(20,20,19,0.18);
    opacity: 0; pointer-events: none;
    transform: translateY(4px);
    transition: opacity 140ms ease, transform 140ms ease;
    white-space: normal; z-index: 30;
  }
  .chip:hover .chip-pop { opacity: 1; transform: translateY(0); }

  .scroll-hint {
    max-width: 1240px; margin: 32px auto 0; padding: 0 40px;
    text-align: center; font-family: var(--sans); font-size: 11px;
    color: var(--stone); letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.7;
  }
  .scroll-hint .dn { display: inline-block; margin: 4px 0; font-size: 18px; line-height: 1; color: var(--terracotta); animation: bob 1800ms ease-in-out infinite; }
  @keyframes bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(4px); } }

  .below {
    max-width: 1240px; margin: 56px auto 0; padding: 0 40px 80px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
  }
  .panel { background: var(--ivory); border: 1px solid var(--border-cream); border-radius: 16px;
    padding: 24px 28px; box-shadow: 0 0 0 1px var(--border-cream); }
  .panel.full { grid-column: 1 / -1; }
  .panel h3 { font-family: var(--serif); font-weight: 500; font-size: 20px; line-height: 1.25;
    color: var(--near-black); margin: 0 0 14px; letter-spacing: -0.005em; }
  .panel .label { font-family: var(--sans); font-size: 10px; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--terracotta); margin-bottom: 8px; }
  .panel p { font-family: var(--sans); font-size: 14px; line-height: 1.65;
    color: var(--charcoal); margin: 0 0 12px; }
  .panel p b { color: var(--near-black); font-weight: 500; }
  .ctr { display: grid; grid-template-columns: 110px 1fr; gap: 10px 20px; font-family: var(--sans); font-size: 13px; }
  .ctr .k { font-size: 10px; font-weight: 500; letter-spacing: 0.10em; text-transform: uppercase; color: var(--olive); padding-top: 4px; }
  .ctr .v { color: var(--charcoal); line-height: 1.55; }
  .ctr .v .pill { display: inline-block; font-family: var(--mono); font-size: 11px;
    background: var(--sand); border: 1px solid var(--ring-warm);
    border-radius: 4px; padding: 1px 7px; margin: 2px 4px 2px 0; color: var(--charcoal); }
  .ctr .v .claim-line-c { padding: 6px 0; border-bottom: 1px dashed var(--border-cream); display: flex; gap: 10px; align-items: baseline; }
  .ctr .v .claim-line-c:last-child { border-bottom: none; }
  .ctr .v .claim-line-c .id { font-family: var(--mono); font-size: 10.5px; color: var(--stone); flex-shrink: 0; width: 130px; }
  .ctr .v .claim-line-c .stmt { color: var(--near-black); font-family: var(--serif); font-size: 14px; line-height: 1.45; }

  .callout { position: absolute; pointer-events: none;
    background: var(--near-black); color: var(--silver);
    border-radius: 10px; padding: 12px 14px;
    font-family: var(--sans); font-size: 12px;
    box-shadow: 0 0 0 1px var(--near-black), 0 12px 32px rgba(20,20,19,0.18);
    opacity: 0; transition: opacity 140ms ease, transform 140ms ease;
    transform: translateY(4px); z-index: 50; min-width: 220px; }
  .callout.show { opacity: 1; transform: translateY(0); }
  .callout-row { display: flex; justify-content: space-between; gap: 14px; margin: 3px 0; }
  .callout-row span { color: var(--silver); }
  .callout-row b { color: #ffffff; font-family: var(--mono); font-weight: 400; font-variant-numeric: tabular-nums; }
  .callout-divider { height: 1px; background: rgba(255,255,255,0.10); margin: 8px 0; }
  .callout-meta { font-family: var(--mono); font-size: 11px; color: var(--silver); margin-top: 4px; }

  .glossbox { position: fixed; max-width: 320px;
    background: var(--ivory); border: 1px solid var(--border-warm);
    border-radius: 12px; padding: 14px 16px;
    box-shadow: 0 0 0 1px var(--ring-warm), 0 12px 32px rgba(20,20,19,0.06);
    font-family: var(--sans); font-size: 13.5px; line-height: 1.55; color: var(--charcoal);
    opacity: 0; transform: translateY(4px);
    transition: opacity 150ms ease, transform 150ms ease;
    pointer-events: none; z-index: 200; }
  .glossbox.show { opacity: 1; transform: translateY(0); }
  .glossbox .label { font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--terracotta); margin-bottom: 6px; }
  .glossbox .term-name { font-family: var(--serif); font-size: 17px; color: var(--near-black); margin-bottom: 6px; line-height: 1.25; }
  .glossbox .formula { font-family: var(--mono); font-size: 12.5px; color: var(--olive); margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border-cream); }

  .drawer { position: fixed; top: 0; right: 0; bottom: 0; width: 440px;
    background: var(--ivory); border-left: 1px solid var(--border-warm);
    box-shadow: -10px 0 32px rgba(20,20,19,0.08);
    transform: translateX(100%);
    transition: transform 280ms cubic-bezier(0.32, 0.72, 0, 1);
    z-index: 100; overflow-y: auto; padding: 28px 32px; }
  .drawer.open { transform: translateX(0); }
  .drawer-close { position: absolute; top: 18px; right: 22px; background: none; border: none; cursor: pointer; color: var(--stone); font-size: 22px; line-height: 1; }
  .drawer-close:hover { color: var(--near-black); }
  .drawer .label { font-family: var(--sans); font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--terracotta); margin-bottom: 8px; }
  .drawer h3 { font-family: var(--serif); font-weight: 500; font-size: 22px; line-height: 1.20; color: var(--near-black); margin: 0 0 6px; }
  .drawer .sub { font-family: var(--mono); font-size: 11px; color: var(--stone); margin-bottom: 22px; word-break: break-all; }
  .drawer-section { margin-bottom: 22px; }
  .drawer-section .stitle { font-family: var(--sans); font-size: 11px; font-weight: 500; letter-spacing: 0.10em; text-transform: uppercase; color: var(--olive); margin-bottom: 10px; }
  .drawer-kv { display: flex; justify-content: space-between; padding: 8px 0; font-family: var(--sans); font-size: 13.5px; color: var(--charcoal); border-bottom: 1px solid var(--border-cream); }
  .drawer-kv b { font-family: var(--mono); font-weight: 400; color: var(--near-black); font-variant-numeric: tabular-nums; }
  .drawer-backdrop { position: fixed; inset: 0; background: rgba(20,20,19,0.18); opacity: 0; pointer-events: none; transition: opacity 280ms ease; z-index: 99; }
  .drawer-backdrop.show { opacity: 1; pointer-events: auto; }

  /* ===== Tap-fallback (any touch device) ===== */
  @media (hover: none) {
    .chip { cursor: pointer; }
    .chip-pop { display: none; }
    .chip.tapped .chip-pop { display: block; opacity: 1; transform: translateY(0); }
    .sym { cursor: pointer; }
  }
  /* On any device, .tapped chips show their popover (used as click toggle on mobile) */
  .chip.tapped .chip-pop { opacity: 1; transform: translateY(0); }

  /* ===== Tablet (640-991px) ===== */
  @media (max-width: 991px) {
    .topbar, .hero, .strip, .scroll-hint, .below { padding-left: 24px; padding-right: 24px; }
    .duo { gap: 14px; }
    .panel-card { padding: 20px 22px 16px; }
    svg.plot { height: 320px; }
    .drawer { width: 380px; }
    .below { grid-template-columns: 1fr; gap: 16px; }
    .panel.full { grid-template-columns: repeat(2, 1fr) !important; }
  }

  /* ===== Mobile (<640px) ===== */
  @media (max-width: 640px) {
    .topbar { grid-template-columns: 1fr; padding: 16px 18px; gap: 8px; }
    .topbar .meta { text-align: left; font-size: 10.5px; }
    .topbar .id { display: inline-block; margin-bottom: 4px; }

    .hero { padding: 24px 18px 20px; }
    .claim-line { flex-direction: column; align-items: flex-start; gap: 10px; margin-bottom: 18px; }
    .claim { font-size: 22px; line-height: 1.20; }
    .claim-tag { padding-top: 0; font-size: 10px; }

    /* Stack the side-by-side */
    .duo { grid-template-columns: 1fr; gap: 14px; }
    .panel-card { padding: 18px 20px 14px; border-radius: 18px; }
    .panel-title { font-size: 14px; margin-bottom: 10px; }
    .paper-img-wrap { padding: 12px 14px; min-height: 200px; }
    .plot-area { min-height: 280px; }
    svg.plot { height: 280px; }
    .ours-controls { position: static; margin-bottom: 10px; }
    .legend-row { gap: 6px; padding-top: 10px; }
    .legend-item { padding: 4px 8px; font-size: 12px; }

    .strip { padding: 0 18px; gap: 6px; margin-top: 14px; }
    .chip { font-size: 11.5px; padding: 6px 12px; min-height: 32px; }
    .chip.spacer { display: none; }
    /* Tap-driven popover on mobile, repositioned to avoid overflow */
    .chip-pop { left: 0; right: 0; bottom: auto; top: calc(100% + 6px); max-width: none; }

    .scroll-hint { margin-top: 24px; padding: 0 18px; font-size: 10px; }

    .below { padding: 0 18px 56px; margin-top: 40px; gap: 14px; }
    .panel { padding: 18px 20px; border-radius: 14px; }
    .panel h3 { font-size: 18px; }
    .panel.full { grid-template-columns: 1fr !important; gap: 14px; padding: 18px 20px !important; }
    .ctr { grid-template-columns: 90px 1fr; gap: 8px 14px; font-size: 12.5px; }

    /* Drawer becomes a bottom sheet */
    .drawer {
      top: auto; bottom: 0; left: 0; right: 0; width: 100%;
      max-height: 80vh; border-left: none; border-top: 1px solid var(--border-warm);
      border-radius: 18px 18px 0 0;
      transform: translateY(100%);
    }
    .drawer.open { transform: translateY(0); }
    .drawer-close { top: 14px; right: 18px; font-size: 26px; padding: 4px 10px; }

    /* Callout repositioned for mobile (closer to top, away from sticky finger) */
    .callout { font-size: 11px; min-width: 200px; }
  }

  /* ===== Touch-friendly point hit area ===== */
  svg.plot .pt { stroke: transparent; stroke-width: 14; paint-order: stroke; }
</style>
</head>
<body>

<div class="topbar">
  <div class="paper">
    <span class="id">__PAPER_ID__</span>
    <b>__AUTHORS__</b> — <em>__PAPER_TITLE__</em>
    __VENUE__ · <a href="__PAPER_URL__">__PAPER_URL_DISPLAY__</a>
  </div>
  <div class="meta">
    __RUN_SCOPE__<br>
    __RUN_META__
  </div>
</div>

<section class="hero">
  <div class="claim-line">
    <h1 class="claim">__HEADLINE_HTML__</h1>
    <span class="claim-tag">__RUN_TAG__</span>
  </div>

  <div class="duo">

    <!-- ===== PAPER PANEL ===== -->
    <div class="panel-card">
      <div class="panel-head">
        <span class="label ref">Reference · the paper</span>
        <span class="source">__PAPER_SOURCE__</span>
      </div>
      <h2 class="panel-title">__PAPER_PANEL_TITLE__</h2>
      <div class="paper-img-wrap">
        <img src="__PAPER_IMG_DATA_URL__" alt="Paper Figure 4(a) — c_L vs h for L=16, 32, 64, 128" />
      </div>
      <div class="paper-cap">
        Curves dip to a <b>negative minimum at h<sub>c</sub> = 1</b>; depth grows mildly with L.
        Away from h<sub>c</sub>, c<sub>L</sub> sits near zero. The four sizes
        nearly collapse onto each other — that is the central claim of size-near-invariance.
      </div>
    </div>

    <!-- ===== OURS PANEL ===== -->
    <div class="panel-card">
      <div class="panel-head">
        <span class="label">Reproduction · this run</span>
        <span class="source">__OURS_SOURCE__</span>
      </div>
      <h2 class="panel-title">__OURS_PANEL_TITLE__</h2>
      <div class="ours-controls">
        <button class="toggle" id="toggle-window">
          <span class="swatch"></span> Match paper y-window
        </button>
      </div>
      <div class="plot-area">
        <svg class="plot" id="plot" viewBox="0 0 600 360" preserveAspectRatio="xMidYMid meet"></svg>
        <div class="callout" id="callout"></div>
      </div>
      <div class="legend-row" id="legend"></div>
    </div>

  </div>

  <div class="strip">
    __STATUS_STRIP_HTML__
  </div>
</section>

<div class="scroll-hint">
  <span class="dn">↓</span><br>
  Contract · Discrepancy · Provenance
</div>

<div class="below">
  <div class="panel">
    <div class="label">Contract</div>
    <h3>Reproduction obligations and accepted deviations.</h3>
    <div class="ctr">__CONTRACT_HTML__</div>
  </div>

  <div class="panel">
    <div class="label">Discrepancy</div>
    <h3>L=128 is close; smaller L deviates positively.</h3>
    __DISCREPANCY_HTML__
  </div>

  <div class="panel full" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; padding: 22px 28px;">
    __PROVENANCE_HTML__
  </div>
</div>

<div class="glossbox" id="glossbox">
  <div class="label">Term</div>
  <div class="term-name" id="gb-name"></div>
  <div id="gb-body"></div>
  <div class="formula" id="gb-formula"></div>
</div>

<div class="drawer-backdrop" id="backdrop" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <button class="drawer-close" onclick="closeDrawer()">×</button>
  <div class="label">Cell manifest</div>
  <h3 id="drawer-title">Cell</h3>
  <div class="sub" id="drawer-sub">—</div>
  <div class="drawer-section">
    <div class="stitle">Result</div>
    <div class="drawer-kv"><span>c<sub>L</sub></span><b id="d-cL">—</b></div>
    <div class="drawer-kv"><span>± 1σ</span><b id="d-se">—</b></div>
    <div class="drawer-kv"><span>95% CI</span><b id="d-ci">—</b></div>
  </div>
  <div class="drawer-section">
    <div class="stitle">Run</div>
    <div class="drawer-kv"><span>Wall</span><b id="d-wall">—</b></div>
    <div class="drawer-kv"><span>N steps</span><b id="d-nsteps">—</b></div>
    <div class="drawer-kv"><span>Accept rate</span><b id="d-accept">—</b></div>
    <div class="drawer-kv"><span>Mean R</span><b id="d-meanR">—</b></div>
    <div class="drawer-kv"><span>Finished</span><b id="d-when">—</b></div>
  </div>
  <div class="drawer-section">
    <div class="stitle">Settings</div>
    <div class="drawer-kv"><span>Bond dimension χ</span><b id="d-chi">—</b></div>
    <div class="drawer-kv"><span>PBC</span><b id="d-pbc">—</b></div>
    <div class="drawer-kv"><span>Estimator</span><b>bridge</b></div>
  </div>
</div>

<script>
  const GLOSS = __GLOSS_JSON__;
  const gb = document.getElementById('glossbox');
  document.querySelectorAll('.sym').forEach(t => {
    t.addEventListener('mouseenter', () => {
      const def = GLOSS[t.dataset.term]; if (!def) return;
      document.getElementById('gb-name').textContent = def.name;
      document.getElementById('gb-body').textContent = def.body;
      const f = document.getElementById('gb-formula');
      f.textContent = def.formula; f.style.display = def.formula ? 'block' : 'none';
      const r = t.getBoundingClientRect();
      gb.style.left = Math.min(r.left, window.innerWidth - 340) + 'px';
      gb.style.top = (r.bottom + 8) + 'px';
      gb.classList.add('show');
    });
    t.addEventListener('mouseleave', () => gb.classList.remove('show'));
  });

  const DATA = __DATA_JSON__;
  const colors = __COLORS_JSON__;

  const W=600, H=360, M={l:54, r:14, t:18, b:42};
  let yMin=-0.75, yMax=1.10;
  const PAPER_Y_LO = -0.55, PAPER_Y_HI = 0.25;
  const xMin=0.78, xMax=1.22;
  const xs = h => M.l + (h - xMin) / (xMax - xMin) * (W - M.l - M.r);
  let ys = c => H - M.b - (c - yMin) / (yMax - yMin) * (H - M.t - M.b);

  function renderPlot() {
    let g = '';
    // paper window highlight (only when toggled)
    g += `<rect class="paper-window" id="paper-window" x="${M.l}" y="${ys(PAPER_Y_HI)}" width="${W-M.l-M.r}" height="${ys(PAPER_Y_LO)-ys(PAPER_Y_HI)}"/>`;
    g += `<text class="paper-window-label" id="paper-window-label" x="${W-M.r-6}" y="${ys((PAPER_Y_LO+PAPER_Y_HI)/2)+4}" text-anchor="end">paper y-window</text>`;
    for (let h = 0.8; h <= 1.2 + 1e-9; h += 0.1) {
      g += `<line class="grid" x1="${xs(h)}" x2="${xs(h)}" y1="${M.t}" y2="${H-M.b}"/>`;
      g += `<text class="tick" x="${xs(h)}" y="${H-M.b+16}" text-anchor="middle">${h.toFixed(1)}</text>`;
    }
    const ystep = (yMax - yMin) > 1.0 ? 0.4 : 0.2;
    for (let c = Math.ceil(yMin/ystep)*ystep; c <= yMax + 1e-9; c += ystep) {
      g += `<line class="grid" x1="${M.l}" x2="${W-M.r}" y1="${ys(c)}" y2="${ys(c)}"/>`;
      g += `<text class="tick" x="${M.l-8}" y="${ys(c)+4}" text-anchor="end">${c.toFixed(1)}</text>`;
    }
    g += `<line class="zero" x1="${M.l}" x2="${W-M.r}" y1="${ys(0)}" y2="${ys(0)}"/>`;
    g += `<line class="hcline" x1="${xs(1.0)}" x2="${xs(1.0)}" y1="${M.t}" y2="${H-M.b}"/>`;
    g += `<text class="hclabel" x="${xs(1.0)+5}" y="${M.t+12}">h<tspan dy="2" font-size="9">c</tspan> = 1</text>`;
    g += `<line class="axis" x1="${M.l}" x2="${W-M.r}" y1="${H-M.b}" y2="${H-M.b}"/>`;
    g += `<line class="axis" x1="${M.l}" x2="${M.l}" y1="${M.t}" y2="${H-M.b}"/>`;
    g += `<text class="axis-label" x="${(W+M.l-M.r)/2}" y="${H-8}" text-anchor="middle">transverse field h</text>`;
    g += `<text class="axis-label" transform="rotate(-90 16 ${(H+M.t-M.b)/2})" x="16" y="${(H+M.t-M.b)/2}" text-anchor="middle">c_L</text>`;

    DATA.Ls.forEach((L, i) => {
      const pts = DATA.cells[L];
      const path = pts.map((p,k) => `${k===0?'M':'L'} ${xs(p.h).toFixed(2)} ${ys(p.cL).toFixed(2)}`).join(' ');
      g += `<path class="curve draw" data-l="${L}" stroke="${colors[i]}" d="${path}" style="animation-delay: ${i*150}ms"/>`;
      pts.forEach((p,k) => {
        // Clip pt visibility if outside view
        const cyTop = ys(p.cL+p.se), cyBot = ys(p.cL-p.se);
        g += `<line class="errbar" data-l="${L}" stroke="${colors[i]}" x1="${xs(p.h)}" x2="${xs(p.h)}" y1="${cyTop}" y2="${cyBot}"/>`;
        const inView = (p.cL >= yMin && p.cL <= yMax);
        g += `<circle class="pt" data-l="${L}" data-k="${k}" cx="${xs(p.h)}" cy="${ys(p.cL)}" r="${inView ? 3.6 : 2.2}" fill="${colors[i]}" opacity="${inView ? 1 : 0.45}"/>`;
      });
    });
    document.getElementById('plot').innerHTML = g;
    bindPoints();
    if (document.getElementById('toggle-window').classList.contains('on')) {
      document.getElementById('paper-window').classList.add('on');
      document.getElementById('paper-window-label').classList.add('on');
    }
  }

  const legend = document.getElementById('legend');
  DATA.Ls.forEach((L, i) => {
    const valAtHc = DATA.cells[L].find(p => Math.abs(p.h - 1.0) < 1e-3);
    const item = document.createElement('div');
    item.className = 'legend-item'; item.dataset.l = L;
    item.innerHTML = `<span class="legend-swatch" style="background:${colors[i]};"></span>
      L = ${L} <span class="legend-val">${valAtHc.cL.toFixed(2)}</span>`;
    item.addEventListener('mouseenter', () => focusL(L));
    item.addEventListener('mouseleave', () => focusL(null));
    legend.appendChild(item);
  });

  function focusL(L) {
    document.querySelectorAll('.curve, .pt, .errbar, .legend-item').forEach(el => el.classList.remove('focus','dim'));
    if (L === null) return;
    document.querySelectorAll('[data-l]').forEach(el => {
      if (+el.dataset.l === L) el.classList.add('focus');
      else el.classList.add('dim');
    });
  }

  const cb = document.getElementById('callout');
  function bindPoints() {
    document.querySelectorAll('.pt').forEach(pt => {
      pt.addEventListener('mouseenter', () => {
        const L = +pt.dataset.l, k = +pt.dataset.k;
        const cell = DATA.cells[L][k];
        focusL(L);
        pt.setAttribute('r', '6');
        cb.innerHTML = `
          <div class="callout-row"><span>L · h</span><b>${L} · ${cell.h.toFixed(2)}</b></div>
          <div class="callout-divider"></div>
          <div class="callout-row"><span>c<sub>L</sub></span><b>${cell.cL.toFixed(4)}</b></div>
          <div class="callout-row"><span>± 1σ</span><b>${cell.se.toFixed(4)}</b></div>
          <div class="callout-divider"></div>
          <div class="callout-row"><span>accept</span><b>${(cell.accept*100).toFixed(1)}%</b></div>
          <div class="callout-row"><span>wall</span><b>${(cell.wall/60).toFixed(1)} min</b></div>
          <div class="callout-meta">${cell.when}</div>
          <div class="callout-meta">${cell.manifest}</div>`;
        const r = pt.getBoundingClientRect();
        const wrap = pt.closest('.plot-area').getBoundingClientRect();
        const left = Math.min(r.left - wrap.left + 14, wrap.width - 250);
        cb.style.left = Math.max(0, left) + 'px';
        cb.style.top = (r.top - wrap.top - 8) + 'px';
        cb.classList.add('show');
      });
      pt.addEventListener('mouseleave', () => {
        const L = +pt.dataset.l, k = +pt.dataset.k;
        const cell = DATA.cells[L][k];
        const inView = (cell.cL >= yMin && cell.cL <= yMax);
        pt.setAttribute('r', inView ? '3.6' : '2.2');
        cb.classList.remove('show');
        focusL(null);
      });
      pt.addEventListener('click', () => {
        openDrawer(DATA.cells[+pt.dataset.l][+pt.dataset.k], +pt.dataset.l);
      });
    });
  }

  const drawer = document.getElementById('drawer');
  const backdrop = document.getElementById('backdrop');
  function openDrawer(cell, L) {
    document.getElementById('drawer-title').textContent = `L = ${L}, h = ${cell.h.toFixed(2)}`;
    document.getElementById('drawer-sub').textContent = `results/__RUN_ID__/cells/${cell.manifest}`;
    document.getElementById('d-cL').textContent = cell.cL.toFixed(4);
    document.getElementById('d-se').textContent = cell.se.toFixed(4);
    document.getElementById('d-ci').textContent = '± ' + (1.96 * cell.se).toFixed(4);
    document.getElementById('d-wall').textContent = (cell.wall/60).toFixed(1) + ' min';
    document.getElementById('d-nsteps').textContent = cell.n_steps.toLocaleString();
    document.getElementById('d-accept').textContent = (cell.accept*100).toFixed(1) + '%';
    document.getElementById('d-meanR').textContent = cell.mean_R.toFixed(3);
    document.getElementById('d-when').textContent = cell.when;
    document.getElementById('d-chi').textContent = cell.chi;
    document.getElementById('d-pbc').textContent = cell.pbc ? 'true' : 'false';
    drawer.classList.add('open');
    backdrop.classList.add('show');
  }
  function closeDrawer() { drawer.classList.remove('open'); backdrop.classList.remove('show'); }
  window.closeDrawer = closeDrawer;
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrawer(); });

  // Toggle: match paper y-window
  const tWin = document.getElementById('toggle-window');
  tWin.addEventListener('click', () => {
    const on = tWin.classList.toggle('on');
    if (on) {
      yMin = PAPER_Y_LO; yMax = PAPER_Y_HI;
    } else {
      yMin = -0.75; yMax = 1.10;
    }
    ys = c => H - M.b - (c - yMin) / (yMax - yMin) * (H - M.t - M.b);
    renderPlot();
  });

  renderPlot();

  // ===== Tap-fallback for hover affordances (chips + glossary terms) =====
  // Detect touch capability; toggle .tapped class on click; tap-outside to dismiss
  const isTouch = matchMedia('(hover: none)').matches;
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', e => {
      e.stopPropagation();
      const wasTapped = chip.classList.contains('tapped');
      document.querySelectorAll('.chip.tapped').forEach(c => c.classList.remove('tapped'));
      if (!wasTapped) chip.classList.add('tapped');
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.chip.tapped').forEach(c => c.classList.remove('tapped'));
  });

  // Glossary term: tap toggles glossbox on touch devices (in addition to hover)
  document.querySelectorAll('.sym').forEach(t => {
    t.addEventListener('click', e => {
      e.stopPropagation();
      const def = GLOSS[t.dataset.term]; if (!def) return;
      const showing = gb.classList.contains('show');
      if (showing) { gb.classList.remove('show'); return; }
      document.getElementById('gb-name').textContent = def.name;
      document.getElementById('gb-body').textContent = def.body;
      const f = document.getElementById('gb-formula');
      f.textContent = def.formula; f.style.display = def.formula ? 'block' : 'none';
      const r = t.getBoundingClientRect();
      gb.style.left = Math.min(r.left, window.innerWidth - 340) + 'px';
      gb.style.top = (r.bottom + 8) + 'px';
      gb.classList.add('show');
    });
  });
  // Tap outside dismisses glossbox on touch
  if (isTouch) {
    document.addEventListener('click', e => {
      if (!e.target.closest('.sym') && !e.target.closest('.glossbox')) {
        gb.classList.remove('show');
      }
    });
  }
</script>
</body>
</html>
